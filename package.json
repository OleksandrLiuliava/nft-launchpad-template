{
  "name": "nft-launchpad-template",
  "version": "1.0.0",
  "description": "A clean, working, easy-to-fork NFT Launchpad template for Sepolia testnet",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
    "verify:sepolia": "hardhat run scripts/verify.ts --network sepolia",
    "mint:test": "hardhat run scripts/mint.ts --network sepolia",
    "upload:pinata": "ts-node scripts/upload-to-pinata.ts",
    "client:dev": "cd client && npm run dev",
    "client:build": "cd client && npm run build"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "dotenv": "^16.3.1",
    "hardhat": "^2.19.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "form-data": "^4.0.0",
    "merkletreejs": "^0.3.11"
  }
}
