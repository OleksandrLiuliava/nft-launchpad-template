# ==========================================
# SMART CONTRACT CONFIGURATION
# ==========================================

# Your wallet private key (NEVER share or commit this!)
PRIVATE_KEY=your_private_key_here

# Sepolia RPC URL (get free one from alchemy.com or infura.io)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-api-key

# Etherscan API key (for contract verification)
ETHERSCAN_API_KEY=your_etherscan_api_key

# Deployer address (for royalty receiver)
DEPLOYER_ADDRESS=0xYourAddressHere

# Contract address (after deployment, for mint script)
CONTRACT_ADDRESS=0xYourDeployedContractAddress

# ==========================================
# PINATA IPFS CONFIGURATION
# ==========================================

# Option 1: JWT token (recommended)
PINATA_JWT=your_pinata_jwt_token

# Option 2: API key + secret
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================

# Deployed contract address (for frontend)
VITE_CONTRACT_ADDRESS=0xYourDeployedContractAddress

# Sepolia RPC URL (for frontend reads)
VITE_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-api-key

# Owner address (enables admin panel in frontend)
VITE_OWNER_ADDRESS=0xYourOwnerAddress
